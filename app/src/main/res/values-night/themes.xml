<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for night mode. -->
    <style name="Base.Theme.NasyidAsShafa" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/black_primary</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">@color/gold_accent_light</item>
        <item name="colorOnPrimaryContainer">@color/black_primary_dark</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/gold_secondary</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="colorSecondaryContainer">@color/gold_secondary_light</item>
        <item name="colorOnSecondaryContainer">@color/black_primary_dark</item>
        
        <!-- Tertiary brand color. -->
        <item name="colorTertiary">@color/gold_accent</item>
        <item name="colorOnTertiary">@color/text_on_primary</item>
        <item name="colorTertiaryContainer">@color/gold_accent_light</item>
        <item name="colorOnTertiaryContainer">@color/black_primary_dark</item>
        
        <!-- Neutral colors -->
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/card_background</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/outline</item>
        
        <!-- Status colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/error</item>
        <item name="colorOnErrorContainer">@color/white</item>
        
        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.NasyidAsShafa.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.NasyidAsShafa.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.NasyidAsShafa.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.NasyidAsShafa.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.NasyidAsShafa.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.NasyidAsShafa.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.NasyidAsShafa.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.NasyidAsShafa.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.NasyidAsShafa.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.NasyidAsShafa.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.NasyidAsShafa.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.NasyidAsShafa.LabelSmall</item>
        
        <!-- Shape -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.NasyidAsShafa.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.NasyidAsShafa.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.NasyidAsShafa.LargeComponent</item>
        
        <!-- Card styling -->
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        
        <!-- FAB styling -->
        <item name="floatingActionButtonStyle">@style/Widget.NasyidAsShafa.FloatingActionButton</item>
        
        <!-- Toolbar styling -->
        <item name="toolbarStyle">@style/Widget.NasyidAsShafa.Toolbar</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/black_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/black_primary</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.NasyidAsShafa" parent="Base.Theme.NasyidAsShafa" />
    
    <!-- Typography Styles -->
    <style name="TextAppearance.NasyidAsShafa.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="TextAppearance.NasyidAsShafa.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Shape Styles -->
    <style name="ShapeAppearance.NasyidAsShafa.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    
    <style name="ShapeAppearance.NasyidAsShafa.MediumComponent" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    
    <style name="ShapeAppearance.NasyidAsShafa.LargeComponent" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
    
    <!-- Component Styles -->
    <style name="Widget.NasyidAsShafa.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/gold_accent</item>
        <item name="tint">@color/text_on_primary</item>
        <item name="shapeAppearance">@style/ShapeAppearance.NasyidAsShafa.LargeComponent</item>
    </style>
    
    <style name="Widget.NasyidAsShafa.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.NasyidAsShafa.TitleLarge</item>
        <item name="subtitleTextAppearance">@style/TextAppearance.NasyidAsShafa.BodyMedium</item>
        <item name="android:background">?attr/colorPrimary</item>
        <item name="titleTextColor">?attr/colorSecondary</item>
        <item name="subtitleTextColor">?attr/colorSecondary</item>
    </style>
    
</resources>